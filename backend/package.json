{
  "name": "reseaux-influences-api",
  "version": "1.0.0",
  "description": "API backend pour Réseaux d'Influence — cartographie des réseaux d'influence avec gamification communautaire",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  }
}
