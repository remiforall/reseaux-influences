generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// UTILISATEURS ET GAMIFICATION
// =============================================================================

model Utilisateur {
  id                     String   @id @default(uuid()) @db.VarChar(36)
  email                  String   @unique @db.VarChar(255)
  motDePasseHash         String   @map("mot_de_passe_hash") @db.VarChar(255)
  nom                    String   @db.VarChar(255)
  pseudo                 String?  @unique @db.VarChar(100)
  bio                    String?  @db.Text
  avatarUrl              String?  @map("avatar_url") @db.VarChar(500)
  role                   Role     @default(CONTRIBUTEUR)

  // Gamification
  points                 Int      @default(0)
  niveau                 Niveau   @default(DEBUTANT)
  validationsEffectuees  Int      @default(0) @map("validations_effectuees")
  soumissionsEffectuees  Int      @default(0) @map("soumissions_effectuees")
  soumissionsAcceptees   Int      @default(0) @map("soumissions_acceptees")
  tauxPrecision          Float    @default(0) @map("taux_precision")

  // Métadonnées
  estActif               Boolean  @default(true) @map("est_actif")
  dateInscription        DateTime @default(now()) @map("date_inscription")
  derniereConnexion      DateTime? @map("derniere_connexion")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  // Relations
  personnesCrees         Personne[]    @relation("PersonneCreeePar")
  organisationsCrees     Organisation[] @relation("OrganisationCreeePar")
  liensCrees             Lien[]        @relation("LienCreePar")
  liensModeres           Lien[]        @relation("LienModerePar")
  sourcesCrees           Source[]      @relation("SourceCreeePar")
  sourcesVerifiees       Source[]      @relation("SourceVerifieePar")
  validations            Validation[]
  badges                 UtilisateurBadge[]
  signalementsCrees      Signalement[]           @relation("SignalementCreePar")
  signalementsTraites    Signalement[]           @relation("SignalementTraitePar")
  historiques            Historique[]
  sitesWebCrees          SiteWeb[]               @relation("SiteWebCreePar")
  auditsEnrichissement   AuditEnrichissement[]   @relation("AuditEnrichissementUtilisateur")
  evenementsCreees       Evenement[]             @relation("EvenementCreeePar")
  demandesDroitTraitees  DemandeDroitPersonne[]  @relation("DemandeDroitTraitePar")

  @@map("utilisateurs")
}

enum Role {
  CONTRIBUTEUR
  MODERATEUR
  ADMIN
}

enum Niveau {
  DEBUTANT
  INTERMEDIAIRE
  EXPERT
  MODERATEUR
}

// =============================================================================
// PERSONNES PUBLIQUES
// =============================================================================

model Personne {
  id              String   @id @default(uuid()) @db.VarChar(36)
  nom             String   @db.VarChar(255)
  prenom          String?  @db.VarChar(255)
  pays            String?  @db.VarChar(100)
  nationalite     String?  @db.VarChar(100)
  dateNaissance   DateTime? @map("date_naissance") @db.Date
  rolePrincipal   String?  @map("role_principal") @db.VarChar(255)
  rolesSecondaires Json     @default("[]") @map("roles_secondaires")
  bio             String?  @db.Text
  photoUrl        String?  @map("photo_url") @db.VarChar(500)
  wikipediaUrl    String?  @map("wikipedia_url") @db.VarChar(500)
  wikidataId      String?  @map("wikidata_id") @db.VarChar(50)

  // Modération
  statut          StatutEntite     @default(EN_ATTENTE)
  qualiteInfluence QualiteInfluence? @map("qualite_influence")
  creePar         Utilisateur?     @relation("PersonneCreeePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId       String?          @map("cree_par") @db.VarChar(36)

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Géolocalisation — lieu de naissance (L2 Passe 4)
  lieuNaissance         String?  @map("lieu_naissance") @db.VarChar(255)
  lieuNaissanceCodeInsee String? @map("lieu_naissance_code_insee") @db.VarChar(10)
  lieuNaissanceLat      Float?   @map("lieu_naissance_lat")
  lieuNaissanceLon      Float?   @map("lieu_naissance_lon")

  // Relations
  liensCommeA     Lien[] @relation("PersonneA")
  liensCommeB     Lien[] @relation("PersonneB")
  participationsEvenement ParticipationEvenement[]

  @@index([wikidataId])
  @@map("personnes")
}

enum StatutEntite {
  EN_ATTENTE
  VALIDE
  REJETE
  ARCHIVE
  CONTESTE
}

// =============================================================================
// ORGANISATIONS (entreprises, institutions, partis, ONG, médias...)
// =============================================================================

model Organisation {
  id                String   @id @default(uuid()) @db.VarChar(36)
  nom               String   @db.VarChar(255)
  sigle             String?  @db.VarChar(50)
  typeOrganisation  TypeOrganisation @map("type_organisation")
  pays              String?  @db.VarChar(100)
  siteWeb           String?  @map("site_web") @db.VarChar(500)
  description       String?  @db.Text
  logoUrl           String?  @map("logo_url") @db.VarChar(500)
  dateCreation      DateTime? @map("date_creation") @db.Date
  dateFin           DateTime? @map("date_fin") @db.Date
  wikipediaUrl      String?  @map("wikipedia_url") @db.VarChar(500)
  wikidataId        String?  @map("wikidata_id") @db.VarChar(50)

  // Modération
  statut            StatutEntite     @default(EN_ATTENTE)
  qualiteInfluence  QualiteInfluence? @map("qualite_influence")
  creePar           Utilisateur?     @relation("OrganisationCreeePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId         String?          @map("cree_par") @db.VarChar(36)

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Géolocalisation du siège social (L2 Passe 4)
  siegeLat          Float?   @map("siege_lat")
  siegeLon          Float?   @map("siege_lon")
  siegeCodeInsee    String?  @map("siege_code_insee") @db.VarChar(10)

  // Adresse textuelle du siège (utilisée pour géocodage BAN)
  adresseSiege      String?  @map("adresse_siege") @db.VarChar(500)

  // Relations — l'organisation peut être côté A ou B d'un lien
  liensCommeA       Lien[] @relation("OrganisationA")
  liensCommeB       Lien[] @relation("OrganisationB")
  participationsEvenement ParticipationEvenement[]

  @@index([wikidataId])
  @@map("organisations")
}

enum TypeOrganisation {
  ENTREPRISE
  INSTITUTION_PUBLIQUE
  PARTI_POLITIQUE
  ONG
  MEDIA
  SYNDICAT
  FONDATION
  THINK_TANK
  LOBBY
  ASSOCIATION
  ORGANISATION_INTERNATIONALE
  AUTRE
}

// =============================================================================
// SOURCES MÉDIATIQUES
// =============================================================================

model Source {
  id                String    @id @default(uuid()) @db.VarChar(36)
  url               String    @db.VarChar(500)
  titre             String    @db.VarChar(500)
  media             String?   @db.VarChar(255)
  typeMedia         TypeMedia? @map("type_media")
  langue            String    @default("fr") @db.VarChar(10)
  paysMedia         String?   @map("pays_media") @db.VarChar(100)
  datePublication   DateTime? @map("date_publication") @db.Date
  dateConsultation  DateTime? @map("date_consultation") @db.Date
  auteur            String?   @db.VarChar(255)
  description       String?   @db.Text

  // Vérification
  verifiee          Boolean   @default(false)
  verifieePar       Utilisateur? @relation("SourceVerifieePar", fields: [verifieeParId], references: [id], onDelete: SetNull)
  verifieeParId     String?   @map("verifiee_par") @db.VarChar(36)
  verifieeLe        DateTime? @map("verifiee_le")

  // Métadonnées
  creePar           Utilisateur? @relation("SourceCreeePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId         String?   @map("cree_par") @db.VarChar(36)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  liens             Lien[]
  evenements        Evenement[]

  @@unique([url(length: 255), datePublication])
  @@map("sources")
}

enum TypeMedia {
  PRESSE_ECRITE
  TELEVISION
  RADIO
  WEB
  DOCUMENT_OFFICIEL
}

// =============================================================================
// TYPES DE LIENS (référentiel)
// =============================================================================

model TypeLien {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(50)
  libelle     String  @db.VarChar(255)
  description String? @db.Text
  categorie   String? @db.VarChar(100)
  icone       String? @db.VarChar(50)
  couleur     String? @db.VarChar(20)

  // Relations
  liens       Lien[]

  @@map("types_liens")
}

// =============================================================================
// LIENS D'INFLUENCE
// =============================================================================

model Lien {
  id                   String       @id @default(uuid()) @db.VarChar(36)

  // Entité A — soit une personne, soit une organisation, soit un site web
  personneA            Personne?    @relation("PersonneA", fields: [personneAId], references: [id], onDelete: Cascade)
  personneAId          String?      @map("personne_a_id") @db.VarChar(36)
  organisationA        Organisation? @relation("OrganisationA", fields: [organisationAId], references: [id], onDelete: Cascade)
  organisationAId      String?      @map("organisation_a_id") @db.VarChar(36)
  siteWebA             SiteWeb?     @relation("LienSiteWebA", fields: [siteWebAId], references: [id], onDelete: Cascade)
  siteWebAId           String?      @map("site_web_a_id") @db.VarChar(36)

  // Entité B — soit une personne, soit une organisation, soit un site web
  personneB            Personne?    @relation("PersonneB", fields: [personneBId], references: [id], onDelete: Cascade)
  personneBId          String?      @map("personne_b_id") @db.VarChar(36)
  organisationB        Organisation? @relation("OrganisationB", fields: [organisationBId], references: [id], onDelete: Cascade)
  organisationBId      String?      @map("organisation_b_id") @db.VarChar(36)
  siteWebB             SiteWeb?     @relation("LienSiteWebB", fields: [siteWebBId], references: [id], onDelete: Cascade)
  siteWebBId           String?      @map("site_web_b_id") @db.VarChar(36)

  typeLien             TypeLien     @relation(fields: [typeLienId], references: [id])
  typeLienId           Int          @map("type_lien_id")
  description          String?      @db.Text
  dateDebut            DateTime?    @map("date_debut") @db.Date
  dateFin              DateTime?    @map("date_fin") @db.Date
  estBidirectionnel    Boolean      @default(true) @map("est_bidirectionnel")
  intensite            Int          @default(1)

  // Source
  source               Source?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceId             String?      @map("source_id") @db.VarChar(36)

  // Modération et consensus
  statut               StatutEntite @default(EN_ATTENTE)
  nbValidationsVrai    Int          @default(0) @map("nb_validations_vrai")
  nbValidationsFaux    Int          @default(0) @map("nb_validations_faux")
  nbValidationsIndecis Int          @default(0) @map("nb_validations_indecis")
  scoreConfiance       Float        @default(0) @map("score_confiance")

  // Contribution
  creePar              Utilisateur? @relation("LienCreePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId            String?      @map("cree_par") @db.VarChar(36)
  moderePar            Utilisateur? @relation("LienModerePar", fields: [modereParId], references: [id], onDelete: SetNull)
  modereParId          String?      @map("modere_par") @db.VarChar(36)
  modereLe             DateTime?    @map("modere_le")

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  // Relations
  validations          Validation[]

  // Indexes sur les FK polymorphes (P-C1) — MySQL ne les crée pas automatiquement
  @@index([personneAId, statut])
  @@index([personneBId, statut])
  @@index([organisationAId, statut])
  @@index([organisationBId, statut])
  @@index([siteWebAId, statut])
  @@index([siteWebBId, statut])
  @@index([statut])
  @@index([typeLienId])
  @@map("liens")
}

// =============================================================================
// VALIDATIONS COMMUNAUTAIRES
// =============================================================================

model Validation {
  id                    String   @id @default(uuid()) @db.VarChar(36)
  utilisateur           Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  utilisateurId         String   @map("utilisateur_id") @db.VarChar(36)
  lien                  Lien     @relation(fields: [lienId], references: [id], onDelete: Cascade)
  lienId                String   @map("lien_id") @db.VarChar(36)
  verdict               Verdict
  commentaire           String?  @db.Text
  sourceSupplementaire  String?  @map("source_supplementaire") @db.VarChar(500)

  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([utilisateurId, lienId])
  @@map("validations")
}

enum Verdict {
  VRAI
  FAUX
  INDECIS
}

// =============================================================================
// BADGES DE GAMIFICATION
// =============================================================================

model Badge {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(50)
  nom         String  @db.VarChar(255)
  description String? @db.Text
  categorie   String  @db.VarChar(100)
  iconeUrl    String? @map("icone_url") @db.VarChar(500)
  couleur     String? @db.VarChar(20)
  conditions  Json
  estActif    Boolean @default(true) @map("est_actif")

  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  utilisateurs UtilisateurBadge[]

  @@map("badges")
}

model UtilisateurBadge {
  id             Int         @id @default(autoincrement())
  utilisateur    Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  utilisateurId  String      @map("utilisateur_id") @db.VarChar(36)
  badge          Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId        Int         @map("badge_id")
  attribueLe     DateTime    @default(now()) @map("attribue_le")

  @@unique([utilisateurId, badgeId])
  @@map("utilisateurs_badges")
}

// =============================================================================
// HISTORIQUE DES MODIFICATIONS
// =============================================================================

model Historique {
  id            String   @id @default(uuid()) @db.VarChar(36)
  entiteType    String   @map("entite_type") @db.VarChar(50)
  entiteId      String   @map("entite_id") @db.VarChar(36)
  action        String   @db.VarChar(50)
  donneesAvant  Json?    @map("donnees_avant")
  donneesApres  Json?    @map("donnees_apres")
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)
  utilisateurId String?  @map("utilisateur_id") @db.VarChar(36)
  commentaire   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("historique")
}

// =============================================================================
// SIGNALEMENTS
// =============================================================================

model Signalement {
  id          String          @id @default(uuid()) @db.VarChar(36)
  entiteType  String          @map("entite_type") @db.VarChar(50)
  entiteId    String          @map("entite_id") @db.VarChar(36)
  signalePar  Utilisateur     @relation("SignalementCreePar", fields: [signaleParId], references: [id], onDelete: Cascade)
  signaleParId String         @map("signale_par") @db.VarChar(36)
  raison      RaisonSignalement
  description String?         @db.Text
  statut      StatutSignalement @default(OUVERT)
  traitePar   Utilisateur?    @relation("SignalementTraitePar", fields: [traiteParId], references: [id], onDelete: SetNull)
  traiteParId String?         @map("traite_par") @db.VarChar(36)
  traiteLe    DateTime?       @map("traite_le")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("signalements")
}

enum RaisonSignalement {
  INEXACT
  DIFFAMATOIRE
  DOUBLON
  SPAM
  AUTRE
}

enum StatutSignalement {
  OUVERT
  EN_COURS
  RESOLU
  REJETE
}

// =============================================================================
// CONFIGURATION GAMIFICATION
// =============================================================================

model ConfigGamification {
  cle         String @id @db.VarChar(100)
  valeur      String @db.VarChar(500)
  description String? @db.Text

  @@map("config_gamification")
}

// =============================================================================
// QUALITÉ D'INFLUENCE PUBLIQUE (ADR-006)
// Garde-fou RGPD art. 85 + LIL art. 80
// =============================================================================

enum QualiteInfluence {
  ELU
  HAUT_FONCTIONNAIRE
  LOBBYISTE
  DIRIGEANT
  ARTISTE
  PRODUCTEUR
  EDITEUR_PRESSE
  HEBERGEUR
  EDITEUR_SITE
  AUTRE
}

// =============================================================================
// SITES WEB (nouvelle entité — ADR-002)
// =============================================================================

model SiteWeb {
  id                 String           @id @default(uuid()) @db.VarChar(36)
  domaine            String           @unique @db.VarChar(255)
  url                String?          @db.VarChar(500)
  titre              String?          @db.VarChar(500)
  description        String?          @db.Text
  dateEnregistrement DateTime?        @map("date_enregistrement") @db.Date
  dateExpiration     DateTime?        @map("date_expiration") @db.Date
  registrar          String?          @db.VarChar(255)
  hebergeurProbable  String?          @map("hebergeur_probable") @db.VarChar(255)
  nameservers        Json             @default("[]")
  titulaireRedacted  Boolean          @default(false) @map("titulaire_redacted")
  statut             StatutEntite     @default(EN_ATTENTE)
  qualiteInfluence   QualiteInfluence? @map("qualite_influence")

  creePar            Utilisateur?     @relation("SiteWebCreePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId          String?          @map("cree_par") @db.VarChar(36)

  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  liensCommeA        Lien[]           @relation("LienSiteWebA")
  liensCommeB        Lien[]           @relation("LienSiteWebB")
  participationsEvenement ParticipationEvenement[]

  @@map("sites_web")
}

// =============================================================================
// PARCELLES CADASTRALES (données IGN)
// =============================================================================

model Parcelle {
  id          String   @id @default(uuid()) @db.VarChar(36)
  idu         String   @unique @db.VarChar(50)
  codeInsee   String   @map("code_insee") @db.VarChar(10)
  section     String   @db.VarChar(10)
  numero      String   @db.VarChar(10)
  contenance  Int?
  commune     String   @db.VarChar(255)
  geometrie   Json?
  source      String   @default("IGN Cadastre") @db.VarChar(100)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("parcelles")
}

// =============================================================================
// ÉVÉNEMENTS HISTORIQUES (Passe 4 — dimension géo-historique)
// =============================================================================

enum TypeEvenement {
  NAISSANCE
  DECES
  ELECTION
  NOMINATION
  DEMISSION
  CREATION_ORGANISATION
  FUSION
  SCISSION
  CESSION
  CONDAMNATION
  PUBLICATION
  CHANGEMENT_DIRIGEANT
  CHANGEMENT_CAPITAL
  AUTRE
}

model Evenement {
  id                String        @id @default(uuid()) @db.VarChar(36)
  date              DateTime      @db.Date
  dateFin           DateTime?     @map("date_fin") @db.Date
  titre             String        @db.VarChar(500)
  description       String?       @db.Text
  typeEvenement     TypeEvenement @map("type_evenement")
  lieu              String?       @db.VarChar(255)
  lieuLat           Float?        @map("lieu_lat")
  lieuLon           Float?        @map("lieu_lon")

  source            Source?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceId          String?       @map("source_id") @db.VarChar(36)

  statut            StatutEntite  @default(EN_ATTENTE)

  // onDelete: SetNull — conservation de l'événement si l'utilisateur est supprimé (RGPD art. 5.2)
  creePar           Utilisateur?  @relation("EvenementCreeePar", fields: [creeParId], references: [id], onDelete: SetNull)
  creeParId         String?       @map("cree_par") @db.VarChar(36)

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  participants      ParticipationEvenement[]

  @@index([date])
  @@index([typeEvenement])
  @@map("evenements")
}

model ParticipationEvenement {
  id             String        @id @default(uuid()) @db.VarChar(36)

  evenement      Evenement     @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  evenementId    String        @map("evenement_id") @db.VarChar(36)

  // Exactement un des trois doit être non-nul (invariant applicatif, cohérent avec ADR-002)
  personne       Personne?     @relation(fields: [personneId], references: [id], onDelete: Cascade)
  personneId     String?       @map("personne_id") @db.VarChar(36)
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  organisationId String?       @map("organisation_id") @db.VarChar(36)
  siteWeb        SiteWeb?      @relation(fields: [siteWebId], references: [id], onDelete: Cascade)
  siteWebId      String?       @map("site_web_id") @db.VarChar(36)

  roleEvenement  String?       @map("role_evenement") @db.VarChar(100)

  @@index([evenementId])
  @@index([personneId])
  @@index([organisationId])
  @@index([siteWebId])
  @@map("participations_evenement")
}

// =============================================================================
// AUDIT ENRICHISSEMENT (traçabilité RGPD)
// =============================================================================

model AuditEnrichissement {
  id                  String       @id @default(uuid()) @db.VarChar(36)
  // onDelete: SetNull — conserver l'audit après suppression d'un utilisateur (ADR-008 / RGPD art. 5.2 accountability)
  utilisateur   Utilisateur? @relation("AuditEnrichissementUtilisateur", fields: [utilisateurId], references: [id], onDelete: SetNull)
  utilisateurId String?      @map("utilisateur_id") @db.VarChar(36)
  dateAction          DateTime     @default(now()) @map("date_action")
  requete             Json
  connecteursUtilises Json         @map("connecteurs_utilises")
  entitesCreees       Json         @map("entites_creees")
  ipAddressTronquee   String?      @map("ip_address_tronquee") @db.VarChar(45)
  creeLe              DateTime     @default(now()) @map("cree_le")

  @@index([utilisateurId, dateAction])
  @@map("audit_enrichissement")
}

// =============================================================================
// DROITS DES PERSONNES CONCERNÉES (RGPD art. 15 à 21)
// Procédure publique de demande — prérequis de levée de l'alpha (ADR-010 → ADR-011).
// Une personne concernée (qui n'est PAS nécessairement un compte contributeur)
// peut demander l'accès, la rectification, l'effacement, la limitation ou
// l'opposition concernant une entité qui la désigne.
//
// Minimisation (art. 5.1.c) : on stocke un email de contact + un nom revendiqué,
// jamais la pièce d'identité elle-même (vérifiée hors-bande). IP tronquée.
// =============================================================================

model DemandeDroitPersonne {
  id                String             @id @default(uuid()) @db.VarChar(36)
  typeDroit         TypeDroitPersonne  @map("type_droit")
  // Entité visée — optionnelle : le demandeur peut ne pas connaître l'id exact
  entiteType        String?            @map("entite_type") @db.VarChar(50)
  entiteId          String?            @map("entite_id") @db.VarChar(36)
  nomRevendique     String             @map("nom_revendique") @db.VarChar(255)
  emailContact      String             @map("email_contact") @db.VarChar(255)
  motif             String             @db.Text
  statut            StatutDemandeDroit @default(RECUE)
  reponse           String?            @db.Text
  // onDelete: SetNull — conserver la trace du traitement après suppression d'un modérateur (art. 5.2)
  traitePar         Utilisateur?       @relation("DemandeDroitTraitePar", fields: [traiteParId], references: [id], onDelete: SetNull)
  traiteParId       String?            @map("traite_par") @db.VarChar(36)
  traiteLe          DateTime?          @map("traite_le")
  ipAddressTronquee String?            @map("ip_address_tronquee") @db.VarChar(45)
  createdAt         DateTime           @default(now()) @map("created_at")

  @@index([statut, createdAt])
  @@map("demandes_droit_personne")
}

enum TypeDroitPersonne {
  ACCES         // art. 15 — droit d'accès
  RECTIFICATION // art. 16 — droit de rectification
  EFFACEMENT    // art. 17 — droit à l'effacement
  LIMITATION    // art. 18 — droit à la limitation
  OPPOSITION    // art. 21 — droit d'opposition
}

enum StatutDemandeDroit {
  RECUE
  EN_COURS
  ACCEPTEE
  REFUSEE
  CLOTUREE
}
